{% extends 'Template/StandardTemplate.html.twig' %}
{% import 'Template/Macros/breadcrumb.html.twig' as breadcrumb %}

{% block title %}Verbinde dich mit Strava{% endblock %}

{% block breadcrumb %}
    {{ breadcrumb.active('Tracks importieren') }}
{% endblock %}

{% block content %}
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <h1>
                    Verbinde dich mit Strava
                </h1>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="text-center">
                    <a href="{{ authorizationUrl }}">
                        <img src="{{ asset('brand/strava/connect.png') }}"
                             srcset="{{ asset('brand/strava/connect@2x.png') }} 2x"
                             alt="Connect with Strava"/>
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
