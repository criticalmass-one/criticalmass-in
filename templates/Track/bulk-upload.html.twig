{% extends 'Template/StandardTemplate.html.twig' %}
{% import 'Template/Macros/breadcrumb.html.twig' as breadcrumb %}

{% block title %}Mehrere Tracks hochladen{% endblock %}

{% block breadcrumb %}
    {{ breadcrumb.active('Tracks hochladen') }}
{% endblock %}

{% block content %}
    <div class="container"
         data-controller="bulk-upload"
         data-bulk-upload-upload-url-value="{{ path('caldera_criticalmass_track_bulkupload_file') }}"
         data-bulk-upload-review-url-value="{{ path('caldera_criticalmass_track_bulkupload_review') }}"
         data-bulk-upload-csrf-token-value="{{ csrf_token('bulk_track_upload') }}">

        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h1>
                    <i class="far fa-cloud-upload text-muted me-2"></i>Mehrere Tracks hochladen
                </h1>
                <p class="text-muted">
                    Zieh beliebig viele <strong>GPX-</strong> oder <strong>FIT-Dateien</strong> in das Feld unten.
                    Jede Datei wird automatisch der passenden Tour zugeordnet. Anschließend kannst du die
                    Zuordnungen prüfen und bestätigen. Dateien ohne passende Tour werden zum späteren Prüfen geparkt.
                </p>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-8 offset-md-2">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="dropzone bulk-upload-dropzone"
                             data-bulk-upload-target="dropzone"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-8 offset-md-2 text-center">
                <a href="{{ path('caldera_criticalmass_track_bulkupload_review') }}"
                   class="btn btn-success d-none"
                   data-bulk-upload-target="reviewLink">
                    <i class="far fa-clipboard-check me-1"></i>Hochgeladene Tracks prüfen
                </a>
            </div>
        </div>
    </div>
{% endblock %}
