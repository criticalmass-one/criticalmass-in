{% extends 'Template/StandardTemplate.html.twig' %}
{% import 'Template/Macros/breadcrumb.html.twig' as breadcrumb %}

{% block title %}Zeit anpassen{% endblock %}

{% block breadcrumb %}
    {{ breadcrumb.item('Dein Benutzerkonto', path('criticalmass_user_usermanagement')) }}
    {{ breadcrumb.item('Deine Tracks', path('caldera_criticalmass_track_list')) }}
    {{ breadcrumb.active('Zeit anpassen') }}
{% endblock %}

{% block content %}
    <div class="container">
        <div class="row mb-4">
            <div class="col-md-12">
                <h1>
                    <i class="far fa-clock text-muted me-2"></i>Zeit anpassen
                </h1>

                <p class="lead">
                    Falls dein Aufzeichnungsgerät aus irgendeinem Grunde eine falsche Uhrzeit bei deinem GPX-Track
                    angegeben haben sollte, kannst du hier den Start-Zeitpunkt deines Tracks verschieben.
                </p>
            </div>
        </div>

        {{ form_start(form) }}

        <div class="row g-4 mb-4">
            <div class="col-md-5 offset-md-1">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white">
                        <h5 class="card-title mb-0">
                            <i class="far fa-clock text-muted me-2"></i>Alte Uhrzeit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Datum:</label>
                            <input class="form-control" type="text" disabled="disabled"
                                   value="{{ track.startDate.format('d.m.Y') }}"/>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Uhrzeit:</label>
                            <input class="form-control" type="text" disabled="disabled"
                                   value="{{ track.startDate.format('H:i') }}"/>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Zeitzone:</label>
                            <input class="form-control" type="text" disabled="disabled"
                                   value="{{ track.ride.city.timezone }}"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white">
                        <h5 class="card-title mb-0">
                            <i class="far fa-edit text-primary me-2"></i>Neue Uhrzeit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Datum:</label>
                            {{ form_widget(form.startDate, { 'attr' : { 'class': 'form-control'} }) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Uhrzeit:</label>
                            {{ form_widget(form.startTime, { 'attr' : { 'class': 'form-control'} }) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Zeitzone:</label>
                            <input class="form-control" type="text" disabled="disabled"
                                   value="{{ track.ride.city.timezone }}"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 text-center">
                <div class="btn-group">
                    <a href="{{ path('caldera_criticalmass_track_list') }}" class="btn btn-outline-secondary btn-sm">
                        Abbrechen
                    </a>
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="far fa-save me-1"></i>Speichern
                    </button>
                </div>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
