{% extends 'Template/StandardTemplate.html.twig' %}
{% import 'Template/Macros/breadcrumb.html.twig' as breadcrumb %}

{% block title %}Deine Tracks{% endblock %}

{% block breadcrumb %}
    {{ breadcrumb.item('Dein Benutzerkonto', path('criticalmass_user_usermanagement')) }}
    {{ breadcrumb.active('Deine Tracks') }}
{% endblock %}

{% block content %}

    <div class="container">
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div id="map" style="height: 400px;">
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <form method="post"
                      action="{{ object_path(track, 'caldera_criticalmass_track_draw') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('track_draw') }}"/>
                    <input type="hidden" id="polyline" name="polyline"/>
                    <input type="hidden" id="geojson" name="geojson"/>

                    <div class="d-flex justify-content-end">
                        <button type="submit" id="save-track" class="btn btn-success btn-sm">
                            <i class="far fa-save me-1"></i>Speichern
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
