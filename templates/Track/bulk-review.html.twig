{% extends 'Template/StandardTemplate.html.twig' %}
{% import 'Template/Macros/breadcrumb.html.twig' as breadcrumb %}

{% block title %}Hochgeladene Tracks prüfen{% endblock %}

{% block breadcrumb %}
    {{ breadcrumb.item('Hochladen', path('caldera_criticalmass_unified_upload')) }}
    {{ breadcrumb.active('Prüfen') }}
{% endblock %}

{% block content %}
    <div class="container">
        {% include 'Flash/_flash.html.twig' %}

        <div class="row">
            <div class="col-md-12">
                <h1>
                    <i class="far fa-clipboard-check text-muted me-2"></i>Hochgeladene Tracks prüfen
                </h1>
                <p class="text-muted">
                    Deine hochgeladenen Dateien wurden automatisch Touren zugeordnet. Bestätige die Treffer,
                    damit sie als Tracks gespeichert werden. Nicht zuordenbare Dateien findest du weiter unten.
                </p>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-12 d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    <i class="far fa-link text-success me-2"></i>Zugeordnete Dateien
                    <span class="badge bg-secondary">{{ matchedCandidates|length }}</span>
                </h3>

                {% if matchedCandidates|length %}
                    <form method="post" action="{{ path('caldera_criticalmass_track_bulkupload_confirm_all') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('bulk_track_review') }}"/>
                        <button type="submit" class="btn btn-success">
                            <i class="far fa-check-double me-1"></i>Alle zugeordneten bestätigen
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>

        {% if matchedCandidates|length %}
            <div class="row g-4 mt-1">
                {% for candidate in matchedCandidates %}
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title text-truncate" title="{{ candidate.originalName }}">
                                    <i class="far fa-file-import text-muted me-1"></i>{{ candidate.originalName }}
                                </h5>

                                <div class="mb-3 rounded overflow-hidden"
                                     data-controller="map--polyline-preview-map"
                                     data-map--polyline-preview-map-polyline-value="{{ candidate.polyline }}"
                                     style="height: 150px;">
                                </div>

                                <dl class="row mb-0 small">
                                    <dt class="col-4">Tour:</dt>
                                    <dd class="col-8">
                                        <a href="{{ object_path(candidate.ride) }}">{{ candidate.ride.title }}</a>
                                    </dd>

                                    <dt class="col-4">Stadt:</dt>
                                    <dd class="col-8">
                                        <a href="{{ object_path(candidate.ride.city) }}">{{ candidate.ride.city.city }}</a>
                                    </dd>

                                    <dt class="col-4">Datum:</dt>
                                    <dd class="col-8">{{ candidate.ride.dateTime|date('d.m.Y H:i') }}&nbsp;Uhr</dd>

                                    <dt class="col-4">Distanz:</dt>
                                    <dd class="col-8">{{ (candidate.distance / 1000)|round(2) }}&nbsp;km</dd>

                                    <dt class="col-4">Start:</dt>
                                    <dd class="col-8">{{ candidate.startDateTime|date('d.m.Y H:i') }}&nbsp;Uhr</dd>

                                    <dt class="col-4">Dauer:</dt>
                                    <dd class="col-8">{{ (candidate.elapsedTime / 60)|round() }}&nbsp;Minuten</dd>
                                </dl>
                            </div>

                            <div class="card-footer bg-white border-0">
                                <div class="btn-group w-100">
                                    <form method="post" class="d-grid"
                                          action="{{ path('caldera_criticalmass_track_bulkupload_confirm', {'id': candidate.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('bulk_track_review') }}"/>
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="far fa-check me-1"></i>Bestätigen
                                        </button>
                                    </form>
                                    <form method="post" class="d-grid"
                                          action="{{ path('caldera_criticalmass_track_bulkupload_reject', {'id': candidate.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('bulk_track_review') }}"/>
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="far fa-times me-1"></i>Verwerfen
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="row mt-2">
                <div class="col-md-12">
                    <p class="text-muted">Keine zugeordneten Dateien zur Bestätigung vorhanden.</p>
                </div>
            </div>
        {% endif %}

        <hr class="my-5"/>

        <div class="row">
            <div class="col-md-12">
                <h3>
                    <i class="far fa-unlink text-muted me-2"></i>Keinem Ride zugeordnet
                    <span class="badge bg-secondary">{{ parkedCandidates|length }}</span>
                </h3>
                <p class="text-muted">
                    Diese Dateien konnten keiner Tour eindeutig zugeordnet werden — etwa, weil noch kein passender
                    Ride existiert oder Zeit/Ort nicht zusammenpassen. Du kannst sie nur verwerfen.
                </p>
            </div>
        </div>

        {% if parkedCandidates|length %}
            <div class="row g-4">
                {% for candidate in parkedCandidates %}
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title text-truncate" title="{{ candidate.originalName }}">
                                    <i class="far fa-file text-muted me-1"></i>{{ candidate.originalName }}
                                </h5>

                                <div class="mb-3 rounded overflow-hidden"
                                     data-controller="map--polyline-preview-map"
                                     data-map--polyline-preview-map-polyline-value="{{ candidate.polyline }}"
                                     style="height: 150px;">
                                </div>

                                <dl class="row mb-0 small">
                                    <dt class="col-4">Distanz:</dt>
                                    <dd class="col-8">{{ (candidate.distance / 1000)|round(2) }}&nbsp;km</dd>

                                    <dt class="col-4">Start:</dt>
                                    <dd class="col-8">{{ candidate.startDateTime|date('d.m.Y H:i') }}&nbsp;Uhr</dd>

                                    <dt class="col-4">Dauer:</dt>
                                    <dd class="col-8">{{ (candidate.elapsedTime / 60)|round() }}&nbsp;Minuten</dd>
                                </dl>
                            </div>

                            <div class="card-footer bg-white border-0">
                                <form method="post" class="d-grid"
                                      action="{{ path('caldera_criticalmass_track_bulkupload_reject', {'id': candidate.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('bulk_track_review') }}"/>
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="far fa-trash me-1"></i>Verwerfen
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="row">
                <div class="col-md-12">
                    <p class="text-muted">Keine ungeordneten Dateien.</p>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
