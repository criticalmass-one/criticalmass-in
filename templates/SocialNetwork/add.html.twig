{% extends 'Template/StandardTemplate.html.twig' %}
{% import 'Template/Macros/breadcrumb.html.twig' as breadcrumb %}

{% block breadcrumb %}
    {{ breadcrumb.item('Städteliste', path('caldera_criticalmass_city_list')) }}
    {% if profileAbleType == 'city' %}
        {{ breadcrumb.item(profileAble.city, object_path(profileAble)) }}
        {{ breadcrumb.item('Soziale Netzwerke', object_path(profileAble, 'criticalmass_socialnetwork_city_list')) }}
        {{ breadcrumb.active('Soziales Netzwerk editieren') }}
    {% endif %}
    {% if profileAbleType == 'ride' %}
        {{ breadcrumb.item(profileAble.city.city, object_path(profileAble.city)) }}
        {{ breadcrumb.item(profileAble.title, object_path(profileAble)) }}
        {{ breadcrumb.item('Soziale Netzwerke', object_path(profileAble, 'criticalmass_socialnetwork_ride_list')) }}
        {{ breadcrumb.active('Soziales Netzwerk editieren') }}
    {% endif %}
{% endblock %}

{% block content %}
    <div class="container">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <h2>
                    Soziales Netzwerk hinzufügen
                </h2>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 offset-md-3">
                {{ form_start(form) }}

                {{ form_errors(form.identifier) }}

                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label class="form-label" for="">Adresse:</label>
                            {{ form_widget(form.identifier, { 'attr' : { 'class': 'form-control'} }) }}
                        </div>
                    </div>
                </div>

                <div class="row">
                     <div class="col-md-12">
                         <div class="btn-group float-end">
                             <a href="" class="btn btn-secondary">
                                 Abbrechen
                             </a>

                             <button type="submit" class="btn btn-primary">
                                 <i class="far fa-save me-1"></i>
                                 Speichern
                             </button>
                         </div>
                     </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
