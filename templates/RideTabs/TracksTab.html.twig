<div role="tabpanel" class="tab-pane fade" id="tracks" aria-labelledby="tracks-tab">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">
            <i class="far fa-route text-muted me-2"></i>
            GPX-Tracks
        </h4>
        <div class="btn-group">
            {% if app.user %}
                <button type="button" class="btn btn-outline-primary btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="far fa-plus me-1"></i>Track hinzufügen
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    {% if feature('strava_track_upload') %}
                        <li>
                            <a class="dropdown-item" href="{{ object_path(ride, 'caldera_criticalmass_strava_auth') }}">
                                <i class="fab fa-strava text-orange me-2"></i>Von Strava importieren
                            </a>
                        </li>
                    {% endif %}
                    <li>
                        <a class="dropdown-item" href="{{ object_path(ride, 'caldera_criticalmass_track_upload') }}" title="Track hochladen">
                            <i class="far fa-upload me-2"></i>GPX-Datei hochladen
                        </a>
                    </li>
                </ul>
            {% else %}
                <button type="button" class="btn btn-outline-primary btn-sm"
                    data-controller="hint-modal"
                    data-modal-hint-title="{{ 'hint_modal.ride.track_upload_button.title'|trans }}"
                    data-modal-hint-text="{{ 'hint_modal.ride.track_upload_button.text'|trans({'%city%': ride.city.city, '%dateTime%': ride.dateTime|date('d.m.Y')}) }}"
                    data-modal-hint-size="md">
                    <i class="far fa-plus me-1"></i>Track hinzufügen
                </button>
            {% endif %}
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            {% if tracks|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width: 40px;">
                                    <input type="checkbox" class="form-check-input allgroups-visibility-toggle" checked="checked" title="Alle ein-/ausblenden"/>
                                </th>
                                <th>Teilnehmer</th>
                                <th class="text-end">Dauer</th>
                                <th class="text-end">Länge</th>
                                <th class="text-end d-none d-md-table-cell">Tempo</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for track in tracks %}
                                <tr>
                                    <td class="text-center" style="background-color: rgba({{ track.getColorRed() }}, {{ track.getColorGreen() }}, {{ track.getColorBlue() }}, 0.3);">
                                        <input type="checkbox" class="form-check-input track-visibility-toggle" data-track-id="{{ track.id }}" checked="checked"/>
                                    </td>
                                    <td>
                                        <i class="far fa-user text-muted me-1"></i>{{ track.user.username }}
                                    </td>
                                    <td class="text-end">
                                        {% if track.getDurationInterval() %}
                                            <span class="text-muted">{{ human_duration(track.getDurationInSeconds()) }}</span>
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% if track.distance %}
                                            <strong>{{ track.distance|round(1) }}</strong> <small class="text-muted">km</small>
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end d-none d-md-table-cell">
                                        {% set track_average_velocity = average_velocity(track) %}
                                        {% if track_average_velocity %}
                                            <span class="text-muted">{{ track_average_velocity|round(1) }} km/h</span>
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="card bg-light border-0">
                    <div class="card-body text-center py-5">
                        <i class="far fa-route fa-3x text-muted mb-3"></i>
                        <h5>Keine Tracks vorhanden</h5>
                        {% if app.getUser() %}
                            <p class="text-muted mb-3">
                                Lade deinen GPX-Track hoch und zeige anderen, wo ihr gefahren seid!
                            </p>
                            <a href="{{ object_path(ride, 'caldera_criticalmass_track_upload') }}" class="btn btn-primary">
                                <i class="far fa-upload me-1"></i>Track hochladen
                            </a>
                        {% else %}
                            <p class="text-muted mb-0">
                                <a href="{{ path('login') }}">Melde dich an</a>, um einen Track hochzuladen.
                            </p>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <div class="card border-0 bg-light"
                 data-controller="timelapse"
                 data-timelapse-city-slug-value="{{ ride.city.mainSlugString }}"
                 data-timelapse-ride-identifier-value="{{ ride.dateTime.format('Y-m-d') }}"
                 data-timelapse-ride-date-time-value="{{ ride.dateTime.format('c') }}">
                <div class="card-body">
                    <h6 class="card-subtitle mb-3 text-muted">
                        <i class="far fa-play-circle me-2"></i>Timelapse
                    </h6>

                    <div data-timelapse-target="controlSection" style="display: none;">
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <small class="text-muted d-block">Uhrzeit</small>
                                <strong><span data-timelapse-target="timeClock">{{ ride.dateTime.format('H:i') }}</span> Uhr</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Verstrichene Zeit</small>
                                <strong><span data-timelapse-target="timeElapsed">0</span> Min</strong>
                            </div>
                        </div>

                        <div class="d-flex justify-content-center mb-3">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Timelapse-Steuerung">
                                <button type="button" class="btn btn-outline-secondary" data-action="click->timelapse#stepBackward">
                                    <i class="far fa-backward"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" data-action="click->timelapse#pause">
                                    <i class="far fa-pause"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" data-action="click->timelapse#stop">
                                    <i class="far fa-stop"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" data-action="click->timelapse#play">
                                    <i class="far fa-play"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" data-action="click->timelapse#stepForward">
                                    <i class="far fa-forward"></i>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">Geschwindigkeit</label>
                            <input type="range" min="1" max="20" value="5" class="form-range w-100"
                                   data-timelapse-target="speedSlider"
                                   data-action="input->timelapse#onSpeedChange"/>
                        </div>

                        <div>
                            <label class="form-label small text-muted">Zeitpunkt</label>
                            <input type="range" min="0" max="100" value="0" class="form-range w-100"
                                   data-timelapse-target="timeSlider"
                                   data-action="input->timelapse#onTimeChange"/>
                        </div>
                    </div>

                    <div data-timelapse-target="startSection">
                        <div class="text-center">
                            {% if tracks|length %}
                                <p class="text-muted small mb-3">Verfolge die Tour im Zeitraffer auf der Karte.</p>
                                <button class="btn btn-success btn-sm" data-action="click->timelapse#start">
                                    <i class="far fa-play me-1"></i>Timelapse starten
                                </button>
                            {% else %}
                                <p class="text-muted small mb-0">
                                    Die Timelapse-Funktion ist verfügbar, sobald mindestens ein GPX-Track hochgeladen wurde.
                                </p>
                            {% endif %}
                        </div>
                    </div>

                    <div data-timelapse-target="loaderSection" style="display: none;">
                        <div class="text-center">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                <span class="visually-hidden">Lädt...</span>
                            </div>
                            Track <span data-timelapse-target="trackNumber">0</span> von <span data-timelapse-target="trackTotal">0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
