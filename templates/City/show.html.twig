{% extends 'Template/StandardTemplate.html.twig' %}
{% import 'Template/Macros/breadcrumb.html.twig' as breadcrumb %}

{% block title %}{{ city.title }}{% endblock %}

{% block breadcrumb %}
    {{ breadcrumb.active(city.city) }}
{% endblock %}

{% block content %}
    <div class="container" itemscope itemtype="http://schema.org/Organization">
        {{ include('Flash/_flash.html.twig') }}

        {{ include('City/Includes/_tabs.html.twig', { tab: 'city' }) }}

        {% if city.imageName %}
            {# Header mit Bild, Titel und Optionen als Overlay #}
            <div class="card border-0 shadow-sm mb-4 overflow-hidden">
                <div class="position-relative">
                    <img src="{{ vich_uploader_asset(city, 'imageFile')|imagine_filter('city_image_wide') }}"
                         alt="{{ city.title }}"
                         class="w-100"
                         style="height: 400px; object-fit: cover;">

                    <div class="position-absolute bottom-0 start-0 end-0 p-4"
                         style="background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));">
                        <div class="d-flex justify-content-between align-items-end">
                            <div>
                                <h1 class="h2 text-white mb-0" itemprop="name">{{ city.title }}</h1>
                                {% if city.punchline %}
                                    <p class="text-white-50 mb-0">{{ city.punchline }}</p>
                                {% endif %}
                            </div>

                            <div class="d-flex gap-2">
                                {% if currentRide %}
                                    <a href="{{ object_path(currentRide) }}" class="btn btn-primary btn-sm">
                                        <i class="far fa-bicycle me-1"></i>Tour anzeigen
                                    </a>
                                {% endif %}

                                {% if app.user %}
                                    <div class="dropdown">
                                        <button type="button" class="btn btn-light btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                            <i class="far fa-cogs me-1"></i>Optionen
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" href="{{ object_path(city, 'caldera_criticalmass_city_edit') }}">
                                                    <i class="far fa-cogs me-2"></i>Stadt editieren
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="{{ object_path(city, 'caldera_criticalmass_ride_add') }}">
                                                    <i class="far fa-plus me-2"></i>Tour hinzufügen
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="{{ object_path(city, 'caldera_criticalmass_citycycle_list') }}">
                                                    <i class="far fa-calendar me-2"></i>Turnus verwalten
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="{{ object_path(city, 'criticalmass_socialnetwork_city_list') }}">
                                                    <i class="far fa-at me-2"></i>Soziale Netzwerke verwalten
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                {% else %}
                                    <button type="button"
                                            class="btn btn-light btn-sm"
                                            data-controller="hint-modal"
                                            data-modal-hint-title="{{ 'hint_modal.city.options_button.title'|trans }}"
                                            data-modal-hint-text="{{ 'hint_modal.city.options_button.text'|trans({'%city%': city.city}) }}"
                                            data-modal-hint-size="md">
                                        <i class="far fa-cogs me-1"></i>Optionen
                                    </button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            {# Kein Header-Bild: Info-Leiste als Card #}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                        <div>
                            <h1 class="h3 mb-1" itemprop="name">{{ city.title }}</h1>
                            {% if city.punchline %}
                                <p class="text-muted mb-0">{{ city.punchline }}</p>
                            {% endif %}
                        </div>

                        <div class="d-flex gap-2">
                            {% if currentRide %}
                                <a href="{{ object_path(currentRide) }}" class="btn btn-primary btn-sm">
                                    <i class="far fa-bicycle me-1"></i>Tour anzeigen
                                </a>
                            {% endif %}

                            {% if app.user %}
                                <div class="dropdown">
                                    <button type="button" class="btn btn-outline-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <i class="far fa-cogs me-1"></i>Optionen
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" href="{{ object_path(city, 'caldera_criticalmass_city_edit') }}">
                                                <i class="far fa-cogs me-2"></i>Stadt editieren
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="{{ object_path(city, 'caldera_criticalmass_ride_add') }}">
                                                <i class="far fa-plus me-2"></i>Tour hinzufügen
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="{{ object_path(city, 'caldera_criticalmass_citycycle_list') }}">
                                                <i class="far fa-calendar me-2"></i>Turnus verwalten
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="{{ object_path(city, 'criticalmass_socialnetwork_city_list') }}">
                                                <i class="far fa-at me-2"></i>Soziale Netzwerke verwalten
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            {% else %}
                                <button type="button"
                                        class="btn btn-outline-success btn-sm"
                                        data-controller="hint-modal"
                                        data-modal-hint-title="{{ 'hint_modal.city.options_button.title'|trans }}"
                                        data-modal-hint-text="{{ 'hint_modal.city.options_button.text'|trans({'%city%': city.city}) }}"
                                        data-modal-hint-size="md">
                                    <i class="far fa-cogs me-1"></i>Optionen
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="row">
            {# Hauptinhalt #}
            <div class="col-lg-8">
                {# Beschreibung #}
                {% if city.longDescription %}
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <div class="content">
                                {{ city.longDescription|markdown }}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="card bg-light border-0 mb-4">
                        <div class="card-body text-center py-5">
                            <i class="far fa-edit fa-3x text-muted mb-3"></i>
                            <h5>Beschreibung fehlt</h5>
                            <p class="text-muted mb-3">
                                Schade, bislang hat noch niemand Informationen über {{ city.city }} hinterlegt.
                            </p>
                            <ul class="list-unstyled text-muted text-start mx-auto" style="max-width: 400px;">
                                <li class="mb-2"><i class="far fa-check me-2"></i>Seit wann gibt es die Critical Mass in {{ city.city }}?</li>
                                <li class="mb-2"><i class="far fa-check me-2"></i>Wie lange dauern eure Touren?</li>
                                <li class="mb-2"><i class="far fa-check me-2"></i>Wo fahrt ihr ungefähr lang?</li>
                                <li class="mb-2"><i class="far fa-check me-2"></i>Welche Probleme gibt es in {{ city.city }} für den Radverkehr?</li>
                            </ul>
                            <a href="{{ object_path(city, 'caldera_criticalmass_city_edit') }}" class="btn btn-primary mt-3">
                                <i class="far fa-edit me-1"></i>{{ city.city }} beschreiben
                            </a>
                        </div>
                    </div>
                {% endif %}

                {# Fotos #}
                {% if feature('photos') and photos|length > 0 %}
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">
                                    <i class="far fa-images text-primary me-2"></i>Fotos aus {{ city.city }}
                                </h5>
                                <a href="{{ object_path(city, 'caldera_criticalmass_city_listgalleries') }}" class="btn btn-outline-primary btn-sm">
                                    <i class="far fa-arrow-right me-1"></i>Alle Fotos
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row g-2">
                                {% for photo in photos %}
                                    <div class="col-6 col-sm-4 col-md-3">
                                        <a href="{{ object_path(photo) }}" class="d-block">
                                            <img class="img-fluid rounded"
                                                 src="{{ vich_uploader_asset(photo, 'imageFile')|imagine_filter('gallery_photo_thumb') }}"
                                                 alt="Foto aus {{ city.city }}"/>
                                        </a>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>

            {# Sidebar #}
            <div class="col-lg-4">
                {% include 'City/Includes/_nextTour.html.twig' with { 'city': city, 'currentRide': currentRide } %}

                {% include 'City/Includes/_socialMedia.html.twig' with { 'city': city } %}

                {% include 'City/Includes/_locations.html.twig' with { 'city': city, 'locations': locations } %}

                {% if nearCities and nearCities|length > 0 %}
                    {% include 'City/Includes/_nearCities.html.twig' with { 'nearCities': nearCities } %}
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
